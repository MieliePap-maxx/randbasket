# Local data, imported retailer catalogues, browser sessions and logs.
data/*
logs/

# Retailer source definitions are safe to share and keep catalogue ingestion
# repeatable. The downloaded catalogue itself remains local.
!data/catalogue/
data/catalogue/*
!data/catalogue/retailer-sources.json

# Dependencies and Expo build state.
node_modules/
mobile/node_modules/
mobile/.expo/
__pycache__/
*.pyc

# Local configuration and secrets. Keep the checked-in example files.
.env
.env.*
!.env.example
cloudflare/.dev.vars
cloudflare/.dev.vars.*
cloudflare/.wrangler/
cloudflare/node_modules/

# Local release artefacts and operating-system clutter.
*.zip
*.log
*.tmp
.DS_Store
Thumbs.db

# Codex and local project tooling.
.agents/
.codex/
